{
  "compilerOptions": {
    "target": "es2019",
    "lib": ["es2019", "esnext"],
    "module": "commonjs",
    "rootDir": "./",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "types": ["node"]
  }
}
